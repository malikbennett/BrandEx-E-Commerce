<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" styleClass="body" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.AuthController">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="450.0" minWidth="250.0" prefWidth="350.0" spacing="16.0" StackPane.alignment="CENTER">
         <children>
            <Label text="Please check your email for a 6 digit OTP code" />
