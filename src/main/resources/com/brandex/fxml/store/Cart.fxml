<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<VBox maxWidth="650.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.CartController">
   <children>
      <HBox alignment="CENTER">
         <children>
            <Label styleClass="title-1" text="My Cart" />
            <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="8.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#undoCart" text="Undo" />
                  <Button mnemonicParsing="false" onAction="#redoCart" text="Redo" />
                  <Button mnemonicParsing="false" onAction="#closeCart" text="Close">
                     <HBox.margin>
                        <Insets left="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </HBox>
      <VBox fx:id="cartBox" alignment="TOP_CENTER">
         <children>
            <Label styleClass="title-1" text="No iItems in Cart" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
   <styleClass>
      <String fx:value="bg-default" />
      <String fx:value="rounded" />
   </styleClass>
</VBox>
