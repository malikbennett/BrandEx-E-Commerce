<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="TOP_LEFT" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.CheckoutController">
    <children>
        <HBox>
            <children>
                <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="10.0" styleClass="card-premium">
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="Checkout" />
                                <Label style="-fx-text-fill: -brand-text-dim;" text="Complete your order by filling the details below." />
                            </children>
                        </VBox>
                        <HBox fillHeight="false" spacing="24.0">
                            <children>
                        <ScrollPane fitToWidth="true" maxHeight="1024.0" styleClass="card-premium" HBox.hgrow="ALWAYS">
                           <content>
                                      <VBox spacing="20.0">
                                          <padding>
                                              <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                          </padding>
                                          <children>
                                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                  <children>
                                                      <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Shipping Information" />
                                                      <Region HBox.hgrow="ALWAYS" />
                                                      <Button mnemonicParsing="false" onAction="#handleUseDefaultValues" style="-fx-background-color: transparent; -fx-text-fill: -brand-primary; -fx-cursor: hand;" text="Use Default Profile Values" />
                                                  </children>
                                              </HBox>
                                              <Separator opacity="0.5" />
                                              <Label style="-fx-text-fill: -brand-text-dim;" text="Full Name" />
                                              <TextField fx:id="nameField" promptText="John Doe" styleClass="search-field-modern" />
                                              <Label style="-fx-text-fill: -brand-text-dim;" text="Phone Number" />
                                              <TextField fx:id="phoneField" promptText="(555) 555-5555" styleClass="search-field-modern" />
                                              <Label style="-fx-text-fill: -brand-text-dim;" text="Shipping Address" />
                                              <TextArea fx:id="addressField" prefRowCount="3" promptText="123 BrandEx St, Tech City, USA" styleClass="search-field-modern" />
                                              <Region prefHeight="10.0" />
                                              <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Payment Selection" />
                                              <Separator opacity="0.5" />
                                              <Label style="-fx-text-fill: -brand-text-dim;" text="Select Method" />
                                              <ComboBox fx:id="paymentComboBox" maxWidth="1.7976931348623157E308" promptText="Choose a payment method..." />
                                              <VBox fx:id="cardDetailsBox" spacing="10.0">
                                                  <children>
                                                      <Label style="-fx-text-fill: -brand-text-dim;" text="Card Number" />
                                                      <TextField fx:id="cardNumberField" promptText="0000 0000 0000 0000" styleClass="search-field-modern" />
                                                  </children>
                                              </VBox>
                                              <Label fx:id="errorLabel" style="-fx-text-fill: #f44336; -fx-font-size: 13;" text="" />
                                          </children>
                                      </VBox>
                           </content>
                        </ScrollPane>
                                <VBox minWidth="300.0" prefWidth="300.0" spacing="20.0" styleClass="card-premium">
                                    <padding>
                                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Order Summary" />
                                        <Separator opacity="0.5" />
                              <ScrollPane fitToWidth="true" maxHeight="450.0" minHeight="100.0">
                                 <content>
                                              <VBox fx:id="orderSummaryBox" maxHeight="100.0" spacing="10.0" />
                                 </content>
                                 <padding>
                                    <Insets right="8.0" />
                                 </padding>
                              </ScrollPane>
                                        <Separator opacity="0.5" />
                                        <HBox>
                                            <children>
                                                <Label style="-fx-text-fill: -brand-text-dim;" text="Subtotal" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="subtotalLabel" text="\$0.00" />
                                            </children>
                                        </HBox>
                                        <HBox>
                                            <children>
                                                <Label style="-fx-text-fill: -brand-text-dim;" text="Shipping" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label text="Free" />
                                            </children>
                                        </HBox>
                                        <Separator opacity="0.5" />
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Total" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="totalLabel" style="-fx-font-weight: 900; -fx-font-size: 22; -fx-text-fill: -brand-primary;" text="\$0.00" />
                                            </children>
                                        </HBox>
                                        <Region prefHeight="10.0" />
                                        <Button fx:id="placeOrderBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handlePlaceOrder" prefHeight="45.0" styleClass="btn-brand" text="PAY NOW" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
        <VBox fx:id="successOverlay" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(36, 38, 41, 0.95);" visible="false">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: -brand-secondary;" text="✓ Order Confirmed!" />
                <Label fx:id="successMessage" style="-fx-font-size: 16; -fx-text-fill: -brand-text-dim;" text="Thank you for your purchase." />
                <Button mnemonicParsing="false" onAction="#handleContinueShopping" prefHeight="40.0" prefWidth="200.0" styleClass="btn-brand" text="Continue Shopping" />
            </children>
        </VBox>
    </children>
</StackPane>
