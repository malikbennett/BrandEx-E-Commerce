<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="-Infinity" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.ProductCatalogController">
   <children>
      <HBox alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" maxWidth="300.0" minWidth="300.0">
               <children>
                  <VBox fx:id="productFilter" alignment="CENTER_LEFT" spacing="24.0">
                     <children>
                        <VBox fx:id="priceFilterBox" alignment="CENTER_LEFT" spacing="16.0">
                           <children>
                              <Label styleClass="text-caption" text="Filter by Price:" />
                              <Separator prefWidth="200.0" />
                              <VBox fx:id="priceSliderBox" alignment="CENTER" spacing="8.0">
                                 <children>
                                    <HBox>
                                       <children>
                                          <Label text="Min:" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Slider fx:id="minPriceSlider" blockIncrement="5.0" majorTickUnit="250.0" max="10000.0" minorTickCount="25" snapToTicks="true" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                    <HBox>
                                       <children>
                                          <Label text="Max:" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Slider fx:id="maxPriceSlider" majorTickUnit="250.0" max="10000.0" minorTickCount="25" snapToTicks="true" value="10000.0" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              <Label fx:id="priceLabel" layoutX="10.0" layoutY="10.0" text="Price: $0 — 10000" />
                           </children>
                        </VBox>
                        <VBox fx:id="categoryFilterBox" alignment="CENTER_LEFT" spacing="16.0">
                           <children>
                              <Label styleClass="text-caption" text="Category" />
                              <Separator prefWidth="200.0" />
                              <VBox fx:id="categoryCheckboxBox" alignment="CENTER_LEFT" spacing="8.0" />
                           </children>
                        </VBox>
                        <VBox fx:id="brandFilterBox" alignment="CENTER_LEFT" layoutX="26.0" layoutY="76.0" spacing="16.0">
                           <children>
                              <Label styleClass="text-caption" text="Brand" />
                              <Separator prefWidth="200.0" />
                              <VBox fx:id="brandCheckboxBox" alignment="CENTER_LEFT" spacing="8.0" />
                           </children>
                        </VBox>
                     </children>
                     <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
            <Separator orientation="VERTICAL" prefHeight="200.0" />
            <VBox HBox.hgrow="ALWAYS">
               <children>
                        <TilePane fx:id="productGrid" hgap="16.0" vgap="16.0">
                           <children>
                              <!-- Products will be dynamically loaded here by ProductCatalogController -->
                           </children>
                           <padding>
                              <Insets top="16.0" />
                           </padding>
                        </TilePane>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="16.0" top="16.0" />
         </padding>
      </HBox>
   </children>
</StackPane>
