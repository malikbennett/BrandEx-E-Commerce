<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="350.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.ProfilePasswordFormController">
   <children>
      <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Change Password" />
      
      <VBox spacing="15.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Current Password" />
                  <PasswordField fx:id="currentPasswordField" promptText="Enter Current Password" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="New Password" />
                  <PasswordField fx:id="newPasswordField" promptText="Enter New Password" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="Confirm New Password" />
                  <PasswordField fx:id="confirmPasswordField" promptText="Confirm New Password" />
               </children>
            </VBox>
         </children>
      </VBox>
      
      <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #f44336;" text="error label" visible="false" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="80.0" text="Cancel" />
            <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSave" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Confirm" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
   </padding>
</VBox>
