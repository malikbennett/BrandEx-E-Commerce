<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.DashboardController">
   <content>
      <!-- Customer Dashboard -->
      <BorderPane fx:id="customerDashboard">
         <top>
            <VBox BorderPane.alignment="CENTER">
               <children>
                  <HBox alignment="CENTER" prefHeight="0.0" spacing="16.0" VBox.vgrow="NEVER">
                     <children>
                        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="8.0">
                           <children>
                              <Button minWidth="-Infinity" mnemonicParsing="false" text="Home" />
                              <HBox fx:id="adminControls" spacing="8.0">
                                 <children>
                                    <Separator orientation="VERTICAL" prefHeight="200.0" />
                                    <Button minWidth="-Infinity" mnemonicParsing="false" text="Manage Products" />
                                    <Button layoutX="120.0" layoutY="10.0" minWidth="-Infinity" mnemonicParsing="false" text="Manage Orders" />
                                    <Button layoutX="10.0" layoutY="10.0" minWidth="-Infinity" mnemonicParsing="false" text="Manage Users" />
                                 </children>
                              </HBox>
                           </children>
                        </HBox>
                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="100% Secure Devilery" />
                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="8.0">
                           <children>
                              <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Need Help? Contact Us: 18006767" />
                              <ComboBox minWidth="-Infinity" promptText="English" />
                              <ComboBox layoutX="140.0" layoutY="10.0" minWidth="-Infinity" promptText="USD" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
                     </padding>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="0.0" spacing="24.0">
                     <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="BRANDEX" />
                        <Label fx:id="welcomeLabel" minWidth="-Infinity" text="Welcome User" />
                        <Region prefWidth="100.0" HBox.hgrow="ALWAYS" />
                        <HBox>
                           <children>
                              <TextField prefWidth="400.0" promptText="Search For Items..." />
                              <Button minWidth="-Infinity" mnemonicParsing="false" text="Search" />
                           </children>
                        </HBox>
                        <Region prefWidth="100.0" HBox.hgrow="ALWAYS" />
                        <HBox spacing="8.0">
                           <children>
                              <Button minWidth="-Infinity" mnemonicParsing="false" text="Order Tracking" />
                              <Button minWidth="-Infinity" mnemonicParsing="false" text="Cart">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                                 </graphic>
                              </Button>
                              <Button minWidth="-Infinity" mnemonicParsing="false" text="Account">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                                 </graphic>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </top>
         <bottom>
            <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="BRANDEX" />
               </children>
            </HBox>
         </bottom>
         <center>
            <StackPane fx:id="contentArea" BorderPane.alignment="CENTER" />
         </center>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding>
      </BorderPane>
   </content>
</ScrollPane>
