<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.ManageProductsController">
   <children>
      <VBox spacing="24.0">
         <children>
            <HBox styleClass="card-premium">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="Inventory Control" />
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-text-fill: -brand-text-dim;" text="Manage and Edit Products" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
               </padding>
            </HBox>
            <VBox spacing="16.0" styleClass="card-premium" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <TextField fx:id="searchField" prefHeight="40.0" prefWidth="350.0" promptText="Search by Product ID, Brand, Name, or Category..." styleClass="search-field-modern" />
                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="40.0" styleClass="btn-secondary" text="⟳  RELOAD" />
                        <Button fx:id="addProductBtn" mnemonicParsing="false" onAction="#handleAddProduct" prefHeight="40.0" styleClass="btn-brand" text="ADD" />
                     </children>
                  </HBox>
                  <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" editable="false" prefWidth="100.0" text="ID" />
                      <TableColumn fx:id="nameColumn" editable="false" prefWidth="150.0" text="NAME" />
                      <TableColumn fx:id="brandColumn" prefWidth="120.0" text="BRAND" />
                        <TableColumn fx:id="descriptionColumn" editable="false" prefWidth="200.0" text="DESCRIPTION" />
                        <TableColumn fx:id="priceColumn" prefWidth="100.0" text="PRICE" />
                        <TableColumn fx:id="stockColumn" editable="false" prefWidth="100.0" text="STOCK" />
                        <TableColumn fx:id="categoryColumn" editable="false" prefWidth="200.0" text="CATEGORY" />
                        <TableColumn fx:id="ratingColumn" editable="false" prefWidth="100.0" text="RATING" />
                        <TableColumn fx:id="imageURLColumn" editable="false" prefWidth="200.0" text="IMAGE URL" />
                        <TableColumn fx:id="dateCreatedColumn" prefWidth="200.0" text="DATE CREATED" />
                        <TableColumn fx:id="actionsColumn" maxWidth="200.0" prefWidth="200.0" text="ACTIONS" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
