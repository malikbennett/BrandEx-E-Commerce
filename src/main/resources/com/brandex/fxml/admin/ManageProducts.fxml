<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.ManageProductsController">
   <children>
      <VBox spacing="20.0">
         <children>
            <Label styleClass="title-1" text="Product Managment" />
            <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="20.0">
               <children>
                  <TextField fx:id="searchField" prefWidth="550.0" promptText="Search Product ID">
                     <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                     </padding>
                  </TextField>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="addProductBtn" mnemonicParsing="false" onAction="#handleAddProduct" text="Add Product" />
               </children>
            </HBox>
            <TableView fx:id="productsTable" minHeight="750.0" VBox.vgrow="ALWAYS">
              <columns>
                  <TableColumn maxWidth="50.0" minWidth="50.0" prefWidth="50.0">
                     <graphic>
                        <CheckBox fx:id="tableCheckBox" mnemonicParsing="false" />
                     </graphic>
                  </TableColumn>
                  <TableColumn fx:id="idColumn" editable="false" prefWidth="300.0" text="ID" />
                <TableColumn fx:id="nameColumn" editable="false" prefWidth="300.0" text="Name" />
                <TableColumn fx:id="brandColumn" prefWidth="200.0" text="Brand" />
                  <TableColumn fx:id="descriptionColumn" editable="false" prefWidth="500.0" text="Description" />
                  <TableColumn fx:id="priceColumn" prefWidth="100.0" text="Price" />
                  <TableColumn fx:id="stockColumn" editable="false" prefWidth="100.0" text="Stock" />
                  <TableColumn fx:id="categoryColumn" editable="false" prefWidth="200.0" text="Category" />
                  <TableColumn fx:id="ratingColumn" editable="false" prefWidth="100.0" text="Rating" />
                  <TableColumn fx:id="imageURLColumn" editable="false" prefWidth="200.0" text="Image URL" />
                  <TableColumn fx:id="dateCreatedColumn" prefWidth="200.0" text="Date Created" />
                  <TableColumn fx:id="actionsColumn" maxWidth="200.0" prefWidth="200.0" text="Actions" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
