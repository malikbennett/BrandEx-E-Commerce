<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.EditUserDialogController">
   <children>
      <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Edit User" />
      <VBox spacing="5.0">
         <children>
            <Label fx:id="userInfoLabel" style="-fx-font-weight: bold;" text="User: username (email)" />
         </children>
      </VBox>
      <VBox spacing="10.0">
         <children>
            <Label text="Status" />
            <ComboBox fx:id="statusComboBox" prefWidth="400.0" />
            <Label text="Role" />
            <ComboBox fx:id="roleComboBox" prefWidth="400.0" />
         </children>
      </VBox>
      <VBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Button fx:id="resetPasswordBtn" mnemonicParsing="false" onAction="#handleResetPassword" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Reset Password" />
            <Label style="-fx-font-size: 10; -fx-text-fill: #7f8c8d;" text="This will send a temporary password via email." />
         </children>
      </VBox>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" text="Cancel" />
            <Button mnemonicParsing="false" onAction="#handleSave" text="Save Changes" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
