<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brandex.ui.ManageUsersController">
   <children>
      <VBox spacing="24.0">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card-premium">
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
               </padding>
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="User Directory" />
                        <Label style="-fx-text-fill: -brand-text-dim;" text="Manage application users, roles, and status" />
                     </children>
                  </VBox>
                  <TextField fx:id="searchField" prefHeight="40.0" prefWidth="350.0" promptText="Search by username or email..." styleClass="search-field-modern" />
               </children>
            </HBox>
            <VBox spacing="16.0" styleClass="card-premium" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="usernameColumn" prefWidth="120.0" text="USERNAME" />
                        <TableColumn fx:id="fullNameColumn" prefWidth="150.0" text="FULL NAME" />
                        <TableColumn fx:id="emailColumn" prefWidth="180.0" text="EMAIL" />
                        <TableColumn fx:id="roleColumn" prefWidth="100.0" text="ROLE" />
                        <TableColumn fx:id="phoneColumn" prefWidth="130.0" text="PHONE" />
                        <TableColumn fx:id="addressColumn" prefWidth="200.0" text="ADDRESS" />
                        <TableColumn fx:id="statusColumn" prefWidth="100.0" text="STATUS" />
                        <TableColumn fx:id="joinedDateColumn" prefWidth="130.0" text="JOINED" />
                        <TableColumn fx:id="actionsColumn" maxWidth="100.0" minWidth="100.0" prefWidth="100.0" text="ACTIONS" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
